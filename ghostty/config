command = /bin/zsh

font-family = GeistMono Nerd Font
font-style-italic = false
font-synthetic-style = false
font-feature = -calt
font-feature = -liga
font-feature = -dlig
font-size = 16
font-thicken = true
adjust-cell-height = 30%

theme = vesper
palette = 6=#ffffff
palette = 14=#ffffff
shell-integration-features = no-cursor
cursor-style = block
cursor-color = FFC799
cursor-style-blink = false
background-opacity = 0.82
background-blur = 250
macos-titlebar-style = hidden
macos-window-buttons = hidden
macos-window-shadow = true
mouse-hide-while-typing = true
window-new-tab-position = end
split-preserve-zoom = navigation
unfocused-split-opacity = 0.5
split-divider-color = #262626

window-padding-x = 12,12
window-padding-y = 6,0
window-save-state = always

#keybind = global:shift+cmd+alt+control+t=toggle_quick_terminal
#keybind = ctrl+h=goto_split:previous
#keybind = ctrl+j=goto_split:bottom
#keybind = ctrl+k=goto_split:top
#keybind = ctrl+l=goto_split:next

keybind = ctrl+a>r=reload_config
keybind = ctrl+a>s=new_split:down
keybind = ctrl+a>v=new_split:right
keybind = ctrl+a>f=toggle_split_zoom
keybind = ctrl+a>o=toggle_tab_overview
keybind = ctrl+a>c=new_tab
keybind = ctrl+a>p=previous_tab
keybind = ctrl+a>n=next_tab
keybind = "ctrl+a>1=goto_tab:1"
keybind = "ctrl+a>2=goto_tab:2"
keybind = "ctrl+a>4=goto_tab:3"

# disable cmd+digit keybinds to avoid conflicts with herdr
keybind = cmd+digit_1=unbind
keybind = cmd+digit_2=unbind
keybind = cmd+digit_3=unbind
keybind = cmd+digit_4=unbind
keybind = cmd+digit_5=unbind
keybind = cmd+digit_6=unbind
keybind = cmd+digit_7=unbind
keybind = cmd+digit_8=unbind
keybind = cmd+digit_9=unbind
keybind = cmd+1=unbind
keybind = cmd+2=unbind
keybind = cmd+3=unbind
keybind = cmd+4=unbind
keybind = cmd+5=unbind
keybind = cmd+6=unbind
keybind = cmd+7=unbind
keybind = cmd+8=unbind
keybind = cmd+9=unbind

scrollback-limit = 50000000

auto-update = check
auto-update-channel = tip

# Vim-mode keybindings for Ghostty.
keybind = alt+v=activate_key_table:vim
keybind = vim/
keybind = vim/j=scroll_page_lines:1
keybind = vim/k=scroll_page_lines:-1
keybind = vim/shift+j=scroll_page_down
keybind = vim/shift+k=scroll_page_up
keybind = vim/g>g=scroll_to_top
keybind = vim/shift+g=scroll_to_bottom
keybind = vim/slash=start_search
keybind = vim/n=navigate_search:next
keybind = vim/space>p=toggle_command_palette
keybind = vim/escape=deactivate_key_table
keybind = vim/q=deactivate_key_table
keybind = vim/i=deactivate_key_table
keybind = vim/catch_all=ignore
